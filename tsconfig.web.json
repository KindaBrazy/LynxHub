{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/**/*",
    "src/cross/**/*",
    "extension/src/renderer/**/*",
    "extension/src/cross/**/*",
    "module/src/**/*"
  ],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "ESNext",
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@lynx_module/*": [
        "module/src/*"
      ],
      "@lynx_extension/*": [
        "extension/src/*"
      ],
      "@lynx/components/*": [
        "src/renderer/main_window/components/*"
      ],
      "@lynx/hooks/*": [
        "src/renderer/main_window/hooks/*"
      ],
      "@lynx/layouts/*": [
        "src/renderer/main_window/layouts/*"
      ],
      "@lynx/plugins/*": [
        "src/renderer/main_window/plugins/*"
      ],
      "@lynx/redux/*": [
        "src/renderer/main_window/redux/*"
      ],
      "@lynx/services/*": [
        "src/renderer/main_window/services/*"
      ],
      "@lynx/types/*": [
        "src/renderer/main_window/types/*"
      ],
      "@lynx/utils/*": [
        "src/renderer/main_window/utils/*"
      ],
      "@lynx/icons/*": [
        "src/renderer/shared/assets/icons/*"
      ],
      "@lynx_cross/*": [
        "src/cross/*"
      ]
    }
  }
}
