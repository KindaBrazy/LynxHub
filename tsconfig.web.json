{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/**/*",
    "src/common/**/*",
    "extension/src/renderer/**/*",
    "extension/src/cross/**/*",
    "module/src/**/*"
  ],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "ESNext",
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@lynx_module/*": [
        "./module/src/*"
      ],
      "@lynx_extension/*": [
        "./extension/src/*"
      ],
      "@lynx_common/*": [
        "./src/common/*"
      ],
      "@lynx/*": [
        "./src/renderer/mainWindow/*"
      ],
      "@lynx_shared/*": [
        "./src/renderer/shared/*"
      ],
      "@lynx_assets/*": [
        "./src/renderer/shared/assets/*"
      ],
    }
  }
}
